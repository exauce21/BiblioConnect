{% extends 'utilisateur/base.html.twig' %}

{% block title %}Catalogue des Livres
{% endblock %}

{% block content %}
	<div class="row">
		<div class="col-12 mb-4">
			<div class="card bg-light">
				<div class="card-body text-center">
					<h1 class="card-title">
						<i class="fas fa-tachometer-alt text-primary"></i>
						Tableau de bord utilisateur
					</h1>
					<p class="card-text">Parcourez tous les livres disponibles et accédez aux détails de chaque ouvrage.</p>
				</div>
			</div>
		</div>

		<div class="col-12 mb-4">
			<form class="row g-2 align-items-center" method="get" action="{{ path('app_search_livre') }}">
				<div class="col-auto flex-grow-1">
					<label for="searchQuery" class="visually-hidden">Rechercher</label>
					<input type="search" id="searchQuery" name="q" class="form-control" placeholder="Rechercher un livre, auteur ou catégorie" value="{{ searchTerm|default('') }}">
				</div>
				<div class="col-auto">
					<button type="submit" class="btn btn-primary">Rechercher</button>
				</div>
				{% if searchTerm is defined and searchTerm != '' %}
					<div class="col-12 mt-2">
						<div class="alert alert-info mb-0" role="alert">
							Résultats pour «
							<strong>{{ searchTerm }}</strong>
							» :
							{{ livres|length }}
							livre{{ livres|length > 1 ? 's' : '' }}
							trouvé{{ livres|length > 1 ? 's' : '' }}.
						</div>
					</div>
				{% endif %}
			</form>
		</div>

		<div class="col-12">
			<div class="row g-4">
				{% for livre in livres %}
					<div class="col-md-3">
						<div class="row g-0 bg-light border rounded overflow-hidden flex-md-row mb-4 shadow-sm h-md-250 position-relative">
							<div class="col p-4 d-flex flex-column position-static">
								<strong class="d-inline-block mb-2 text-primary-emphasis">{{ livre.categorie ? livre.categorie.libelle : 'Catégorie' }}</strong>
								<h3 class="mb-0">{{ livre.titre }}</h3>
								<div class="mb-1 text-body-secondary">{{ livre.annee ? : 'Date inconnue' }}</div>
								<p class="card-text mb-auto">{{ livre.auteur ? livre.auteur.nom : 'Aucun auteur' }}</p>
								<p class="card-text mb-auto">{{ livre.description ? : 'Aucune description disponible.' }}</p>
								<a href="{{ path('app_utilisateur_livre_show', {id: livre.id}) }}" class="icon-link gap-1 icon-link-hover stretched-link btn btn-outline-primary btn-sm mt-2">
									Voir le livre
									<svg class="bi" aria-hidden="true" width="16" height="16"><use xlink:href="#chevron-right"/></svg>
								</a>
							</div>
							<div class="col-auto d-none d-lg-block">
								<img src="/uploads/files/{{ livre.imageCouverture }}" class="bd-placeholder-img" width="200" height="280">
							</div>
						</div>
					</div>
				{% else %}
					<div class="col-12">
						<div class="alert alert-warning" role="alert">
							Aucun livre disponible pour le moment.
						</div>
					</div>
				{% endfor %}
			</div>
		</div>
	</div>
{% endblock %}
