<form method="post" action="{{ path('app_commentaire_delete', {'id': commentaire.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer ce commentaire ?');" class="d-inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commentaire.id) }}">
    <button class="btn btn-danger btn-sm">Supprimer</button>
</form>
