{% extends 'utilisateur/base.html.twig' %}

{% block title %}Modifier le commentaire{% endblock %}

{% block content %}
    <div class="card shadow-sm">
        <div class="card-header">
            <h2 class="h5 mb-0">Modifier le commentaire</h2>
        </div>
        <div class="card-body">
            {{ include('commentaire/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('app_commentaire_index') }}" class="btn btn-secondary btn-sm">Retour à la liste</a>
            {{ include('utilisateur/commentaire/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
