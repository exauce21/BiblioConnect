{% extends 'utilisateur/base.html.twig' %}

{% block title %}
	{{ livre.titre }}
	- Détails du livre
{% endblock %}

{% block content %}
	<div class="row">
		<div class="col-lg-8">
			<div class="card shadow-sm">
				<div class="card-body">
					<div class="row">
						<div class="col-md-4 mb-3">
							{% if livre.imageCouverture %}
								<img src="/uploads/files/{{ livre.imageCouverture }}" class="img-fluid rounded shadow-sm" alt="{{ livre.titre }}">
							{% else %}
								<div class="bg-light d-flex align-items-center justify-content-center rounded shadow-sm" style="height: 300px;">
									<i class="fas fa-book fa-3x text-muted"></i>
								</div>
							{% endif %}
						</div>
						<div class="col-md-8">
							<h1 class="h2 mb-3">{{ livre.titre }}</h1>

							<div class="row mb-3">
								<div class="col-sm-6">
									<strong class="text-muted">Auteur:</strong><br>
									{% if livre.auteur %}
										<span class="badge bg-secondary">{{ livre.auteur.nom }}</span>
									{% else %}
										<span class="text-muted">Auteur inconnu</span>
									{% endif %}
								</div>
								<div class="col-sm-6">
									<strong class="text-muted">Catégorie:</strong><br>
									{% if livre.categorie %}
										<span class="badge bg-primary">{{ livre.categorie.libelle }}</span>
									{% else %}
										<span class="text-muted">Non catégorisé</span>
									{% endif %}
								</div>
							</div>

							<div class="row mb-3">
								<div class="col-sm-6">
									<strong class="text-muted">Année de publication:</strong><br>
									{% if livre.annee %}
										{{ livre.annee }}
									{% else %}
										<span class="text-muted">Non spécifiée</span>
									{% endif %}
								</div>
								<div class="col-sm-6">
									<strong class="text-muted">Langue:</strong><br>
									{% if livre.langue %}
										<span class="badge bg-info">{{ livre.langue.titre }}</span>
									{% else %}
										<span class="text-muted">Non spécifiée</span>
									{% endif %}
								</div>
							</div>

							<div class="row mb-3">
								<div class="col-sm-6">
									<strong class="text-muted">Stock disponible:</strong><br>
									{% if livre.stockDisponible > 0 %}
										<span class="badge bg-success">{{ livre.stockDisponible }}</span>
									{% else %}
										<span class="badge bg-danger">Indisponible</span>
									{% endif %}
								</div>
								<div class="col-sm-6">
									{% if livre.created %}
										<div class="mb-3">
											<strong class="text-muted">Ajouté le:</strong><br>
											<small class="text-muted">{{ livre.created|date('d/m/Y à H:i') }}</small>
										</div>
									{% endif %}
								</div>
							</div>
							{% if livre.description %}
								<div class="mb-3">
									<strong class="text-muted">Description:</strong><br>
									<p>{{ livre.description }}</p>
								</div>
							{% endif %}

						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="col-lg-4">
			<div class="card shadow-sm mb-4">
				<div class="card-header">
					<h5 class="mb-0">
						<i class="fas fa-cogs"></i>
						Actions</h5>
				</div>
				<div class="card-body">
					{% if livre.stockDisponible > 0 %}
						<button class="btn btn-success btn-lg w-100 mb-2" onclick="alert('Fonctionnalité de réservation à implémenter')">
							<i class="fas fa-calendar-plus"></i>
							Réserver ce livre
						</button>
					{% else %}
						<button class="btn btn-secondary btn-lg w-100 mb-2" disabled>
							<i class="fas fa-times"></i>
							Livre indisponible
						</button>
					{% endif %}

					<form method="post" action="{{ path('app_favori_toggle', {'id': livre.id}) }}" class="d-inline">
						<input type="hidden" name="_token" value="{{ csrf_token('toggle_favorite') }}">
						<button type="submit" class="btn btn-outline-primary btn-lg w-100 mb-2">
							<i class="fas fa-heart"></i>
							{% set isFavorite = false %}
							{% for favori in app.user.favoris %}
								{% if favori.livre.id == livre.id %}
									{% set isFavorite = true %}
								{% endif %}
							{% endfor %}
							{% if isFavorite %}
								Retirer des favoris
							{% else %}
								Ajouter aux favoris
							{% endif %}
						</button>
					</form>

					<a href="{{ path('app_utilisateur') }}" class="btn btn-outline-secondary btn-lg w-100">
						<i class="fas fa-arrow-left"></i>
						Retour au catalogue
					</a>
				</div>
			</div>

			{% if livre.auteur and livre.auteur.biographie %}
				<div class="card shadow-sm">
					<div class="card-header">
						<h5 class="mb-0">
							<i class="fas fa-user"></i>
							À propos de l'auteur</h5>
					</div>
					<div class="card-body">
						<h6>{{ livre.auteur.nom }}</h6>
						<p class="small mb-0">{{ livre.auteur.biographie }}</p>
					</div>
				</div>
			{% endif %}
		</div>
	</div>

	<!-- Comments Section -->
	<div class="row mt-4">
		<div class="col-12">
			<div class="card shadow-sm">
				<div class="card-header">
					<h5 class="mb-0">
						<i class="fas fa-comments"></i>
						Commentaires et avis</h5>
				</div>
				<div class="card-body">
					{% if livre.commentaires|length > 0 %}
						<div class="comments-list mb-4">
							{% for commentaire in livre.commentaires %}
								<div class="comment-item border-bottom pb-3 mb-3">
									<div class="d-flex justify-content-between align-items-start">
										<div>
											<strong>{{ commentaire.utilisateur.nom }}</strong>
											<small class="text-muted ms-2">{{ commentaire.createdAt|date('d/m/Y à H:i') }}</small>
										</div>
										{% if commentaire.note %}
											<div class="rating">
												{% for i in 1..5 %}
													<i class="fas fa-star{% if i > commentaire.note %}-o{% endif %} text-warning"></i>
												{% endfor %}
												<small class="text-muted ms-1">({{ commentaire.note }}/5)</small>
											</div>
										{% endif %}
									</div>
									{% if commentaire.contenu %}
										<p class="mt-2 mb-0">{{ commentaire.contenu }}</p>
									{% endif %}
								</div>
							{% endfor %}
						</div>
					{% else %}
						<p class="text-muted mb-4">Aucun commentaire pour le moment. Soyez le premier à donner votre avis !</p>
					{% endif %}

					{% if app.user %}
						<div class="comment-form">
							<h6>Ajouter un commentaire</h6>
							{{ form_start(commentForm) }}
							<div class="row">
								<div class="col-md-6">
									{{ form_row(commentForm.note, {'attr': {'class': 'form-control'}}) }}
								</div>
							</div>
							<div class="mb-3">
								{{ form_row(commentForm.contenu, {'attr': {'class': 'form-control', 'rows': 3, 'placeholder': 'Partagez votre avis sur ce livre...'}}) }}
							</div>
							<button type="submit" class="btn btn-primary">
								<i class="fas fa-paper-plane"></i>
								Publier le commentaire
							</button>
							{{ form_end(commentForm) }}
						</div>
					{% else %}
						<div class="alert alert-info">
							<i class="fas fa-info-circle"></i>
							<a href="{{ path('app_login') }}" class="alert-link">Connectez-vous</a>
							pour laisser un commentaire.
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>
{% endblock %}
