<form method="post" action="{{ path('app_favori_delete', {'id': favori.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer ce favori ?');" class="d-inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ favori.id) }}">
    <button class="btn btn-danger btn-sm">Supprimer</button>
</form>
