{% extends 'utilisateur/base.html.twig' %}

{% block title %}Favori{% endblock %}

{% block content %}
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">Détail du favori</h2>
            <div>
                <a href="{{ path('app_favori_edit', {'id': favori.id}) }}" class="btn btn-sm btn-primary me-2">Modifier</a>
                {{ include('utilisateur/favori/_delete_form.html.twig') }}
            </div>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">{{ favori.id }}</dd>
            </dl>
        </div>
        <div class="card-footer text-end">
            <a href="{{ path('app_favori_index') }}" class="btn btn-secondary btn-sm">Retour aux favoris</a>
        </div>
    </div>
{% endblock %}
