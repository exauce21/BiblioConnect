{% extends 'utilisateur/base.html.twig' %}

{% block title %}Modifier le favori{% endblock %}

{% block content %}
    <div class="card shadow-sm">
        <div class="card-header">
            <h2 class="h5 mb-0">Modifier le favori</h2>
        </div>
        <div class="card-body">
            {{ include('utilisateur/favori/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('app_favori_index') }}" class="btn btn-secondary btn-sm">Retour aux favoris</a>
            {{ include('utilisateur/favori/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
