{% extends 'utilisateur/base.html.twig' %}

{% block title %}Réservations{% endblock %}

{% block content %}
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="h5 mb-0">Mes réservations</h2>
                <p class="text-muted small mb-0">Vos réservations de livres en cours et passées.</p>
            </div>
            <a href="{{ path('app_reservation_new') }}" class="btn btn-primary btn-sm">Nouvelle réservation</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Date début</th>
                            <th>Date fin</th>
                            <th>Date retour réel</th>
                            <th>Statut</th>
                            <th>Créé le</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for reservation in reservations %}
                        <tr>
                            <td>{{ reservation.id }}</td>
                            <td>{{ reservation.dateDebut ? reservation.dateDebut|date('Y-m-d') : '' }}</td>
                            <td>{{ reservation.dateFin ? reservation.dateFin|date('Y-m-d') : '' }}</td>
                            <td>{{ reservation.dateRetourReel ? reservation.dateRetourReel|date('Y-m-d') : '' }}</td>
                            <td>{{ reservation.statut ? 'Oui' : 'Non' }}</td>
                            <td>{{ reservation.created ? reservation.created|date('Y-m-d H:i:s') : '' }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_reservation_show', {'id': reservation.id}) }}" class="btn btn-sm btn-outline-secondary me-1">Voir</a>
                                <a href="{{ path('app_reservation_edit', {'id': reservation.id}) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-4">Aucune réservation trouvée.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
