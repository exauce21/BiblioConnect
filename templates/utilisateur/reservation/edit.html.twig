{% extends 'utilisateur/base.html.twig' %}

{% block title %}Modifier la réservation{% endblock %}

{% block content %}
    <div class="card shadow-sm">
        <div class="card-header">
            <h2 class="h5 mb-0">Modifier la réservation</h2>
        </div>
        <div class="card-body">
            {{ include('reservation/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('app_reservation_index') }}" class="btn btn-secondary btn-sm">Retour aux réservations</a>
            {{ include('reservation/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
