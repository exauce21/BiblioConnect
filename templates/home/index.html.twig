{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <div class="container py-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h3 mb-3">Bienvenue sur BiblioConnect</h1>
                <p class="text-muted mb-4">Le système de gestion de bibliothèque en Symfony.</p>
                <p>Cette page est générée par la méthode <code>HomeController::index()</code> et le template <code>templates/home/index.html.twig</code>.</p>
                <div class="mt-4">
                    <a href="{{ path('app_login') }}" class="btn btn-primary me-2">Se connecter</a>
                    <a href="{{ path('app_user_new') }}" class="btn btn-outline-secondary">Créer un compte</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
