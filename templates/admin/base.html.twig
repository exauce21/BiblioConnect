{% extends 'base.html.twig' %}

{% block title %}{% block admin_title %}BiblioConnect Admin{% endblock %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" integrity="sha512-+okHMr7Ffvw0g+oCUB4EQtJ4+nK9b4EL7q4/EcplI7/P+FvPIs4o6Bq0DrY3vAcd49UAkx3YwWwhxQ7zE0z3gQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
{% endblock %}

{% block body %}
    <div class="container-fluid">
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
            <div class="container-fluid">
                <a class="navbar-brand" href="{{ path('app_bibliothecaire') }}">
                    <i class="fas fa-book"></i> BiblioConnect
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar" aria-controls="adminNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="adminNavbar">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="gestionDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-cogs"></i> Gestion
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="gestionDropdown">
                                <li><a class="dropdown-item" href="{{ path('app_user_index') }}"><i class="fas fa-users"></i> Utilisateurs</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_auteur_index') }}"><i class="fas fa-user-edit"></i> Auteurs</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_categorie_index') }}"><i class="fas fa-tags"></i> Catégories</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_langue_index') }}"><i class="fas fa-language"></i> Langues</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="collectionDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-book-open"></i> Collection
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="collectionDropdown">
                                <li><a class="dropdown-item" href="{{ path('app_livre_index') }}"><i class="fas fa-book"></i> Livres</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_reservation_index') }}"><i class="fas fa-calendar-check"></i> Réservations</a></li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}"><i class="fas fa-home"></i> Accueil</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>
                    </ul>
                </div>
            </div>
        </nav>

        <main class="container mb-5">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <div>
                            <h1 class="h3 mb-0"><i class="fas fa-tachometer-alt me-2"></i>{% block admin_header_title %}{{ block('admin_title') }}{% endblock %}</h1>
                        </div>
                        {% block admin_header_actions %}{% endblock %}
                    </div>
                </div>
            </div>

            {% block admin_body %}{% endblock %}
        </main>
    </div>
{% endblock %}
