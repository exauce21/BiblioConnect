{% extends 'admin/base.html.twig' %}

{% block admin_title %}Admin Dashboard
{% endblock %}

{% block admin_body %}
	<div class="row">
		<!-- Welcome Section -->
		<div class="col-12 mb-4">
			<div class="card bg-light">
				<div class="card-body text-center">
					<h1 class="card-title">
						<i class="fas fa-tachometer-alt text-primary"></i>
						Bienvenue dans le Dashboard Bibliothécaire
					</h1>
					<p class="card-text">Gérez votre bibliothèque efficacement avec tous les outils nécessaires.</p>
					<div class="row mt-4 g-3">
						<div class="col-12 col-sm-6 col-lg-4 col-xl-2">
							<div class="card h-100 shadow-sm">
								<div class="card-body text-center">
									<i class="fas fa-users fa-2x text-primary mb-2"></i>
									<h5 class="card-title">Utilisateurs</h5>
									<h2 class="display-6">{{ userCount }}</h2>
									<p class="card-text">Gérer les comptes utilisateurs</p>
									<a href="{{ path('app_user_index') }}" class="btn btn-primary btn-sm">Voir</a>
								</div>
							</div>
						</div>
						<div class="col-12 col-sm-6 col-lg-4 col-xl-2">
							<div class="card h-100 shadow-sm">
								<div class="card-body text-center">
									<i class="fas fa-book fa-2x text-success mb-2"></i>
									<h5 class="card-title">Livres</h5>
									<h2 class="display-6">{{ livreCount }}</h2>
									<p class="card-text">Gérer la collection de livres</p>
									<a href="{{ path('app_livre_index') }}" class="btn btn-success btn-sm">Voir</a>
								</div>
							</div>
						</div>
						<div class="col-12 col-sm-6 col-lg-4 col-xl-2">
							<div class="card h-100 shadow-sm">
								<div class="card-body text-center">
									<i class="fas fa-user-edit fa-2x text-info mb-2"></i>
									<h5 class="card-title">Auteurs</h5>
									<h2 class="display-6">{{ auteurCount }}</h2>
									<p class="card-text">Gérer les auteurs</p>
									<a href="{{ path('app_auteur_index') }}" class="btn btn-info btn-sm">Voir</a>
								</div>
							</div>
						</div>
						<div class="col-12 col-sm-6 col-lg-4 col-xl-2">
							<div class="card h-100 shadow-sm">
								<div class="card-body text-center">
									<i class="fas fa-tags fa-2x text-secondary mb-2"></i>
									<h5 class="card-title">Catégories</h5>
									<h2 class="display-6">{{ categorieCount }}</h2>
									<p class="card-text">Gérer les catégories</p>
									<a href="{{ path('app_categorie_index') }}" class="btn btn-secondary btn-sm">Voir</a>
								</div>
							</div>
						</div>
						<div class="col-12 col-sm-6 col-lg-4 col-xl-2">
							<div class="card h-100 shadow-sm">
								<div class="card-body text-center">
									<i class="fas fa-calendar-check fa-2x text-warning mb-2"></i>
									<h5 class="card-title">Réservations</h5>
									<h2 class="display-6">{{ reservationCount }}</h2>
									<p class="card-text">Gérer les réservations</p>
									<a href="{{ path('app_reservation_index') }}" class="btn btn-warning btn-sm">Voir</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Add Font Awesome for icons -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
{% endblock %}
