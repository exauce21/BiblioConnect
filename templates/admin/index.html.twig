{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}
<div class="container-fluid">
    <!-- Header Navigation Menu -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container-fluid">
            <a class="navbar-brand" href="{{ path('app_admin') }}">
                <i class="fas fa-book"></i> Admin Dashboard
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="gestionDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-cogs"></i> Gestion
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="gestionDropdown">
                            <li><a class="dropdown-item" href="{{ path('app_user_index') }}">
                                <i class="fas fa-users"></i> Utilisateurs
                            </a></li>
                            <li><a class="dropdown-item" href="{{ path('app_auteur_index') }}">
                                <i class="fas fa-user-edit"></i> Auteurs
                            </a></li>
                            <li><a class="dropdown-item" href="{{ path('app_categorie_index') }}">
                                <i class="fas fa-tags"></i> Catégories
                            </a></li>
                            <li><a class="dropdown-item" href="{{ path('app_langue_index') }}">
                                <i class="fas fa-language"></i> Langues
                            </a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="collectionDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-book-open"></i> Collection
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="collectionDropdown">
                            <li><a class="dropdown-item" href="{{ path('app_livre_index') }}">
                                <i class="fas fa-book"></i> Livres
                            </a></li>
                            <li><a class="dropdown-item" href="{{ path('app_reservation_index') }}">
                                <i class="fas fa-calendar-check"></i> Réservations
                            </a></li>
                        </ul>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_home') }}">
                            <i class="fas fa-home"></i> Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">
                            <i class="fas fa-sign-out-alt"></i> Déconnexion
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Dashboard Content -->
    <div class="row">
        <!-- Welcome Section -->
        <div class="col-12 mb-4">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h1 class="card-title">
                        <i class="fas fa-tachometer-alt text-primary"></i>
                        Bienvenue dans le Dashboard Bibliothécaire
                    </h1>
                    <p class="card-text">Gérez votre bibliothèque efficacement avec tous les outils nécessaires.</p>
                    <div class="row mt-4 g-3">
                        <div class="col-12 col-sm-6 col-lg-4 col-xl-2">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <i class="fas fa-users fa-2x text-primary mb-2"></i>
                                    <h5 class="card-title">Utilisateurs</h5>
                                    <h2 class="display-6">{{ userCount }}</h2>
                                    <p class="card-text">Gérer les comptes utilisateurs</p>
                                    <a href="{{ path('app_user_index') }}" class="btn btn-primary btn-sm">Voir</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-lg-4 col-xl-2">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <i class="fas fa-book fa-2x text-success mb-2"></i>
                                    <h5 class="card-title">Livres</h5>
                                    <h2 class="display-6">{{ livreCount }}</h2>
                                    <p class="card-text">Gérer la collection de livres</p>
                                    <a href="{{ path('app_livre_index') }}" class="btn btn-success btn-sm">Voir</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-lg-4 col-xl-2">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <i class="fas fa-user-edit fa-2x text-info mb-2"></i>
                                    <h5 class="card-title">Auteurs</h5>
                                    <h2 class="display-6">{{ auteurCount }}</h2>
                                    <p class="card-text">Gérer les auteurs</p>
                                    <a href="{{ path('app_auteur_index') }}" class="btn btn-info btn-sm">Voir</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-lg-4 col-xl-2">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <i class="fas fa-tags fa-2x text-secondary mb-2"></i>
                                    <h5 class="card-title">Catégories</h5>
                                    <h2 class="display-6">{{ categorieCount }}</h2>
                                    <p class="card-text">Gérer les catégories</p>
                                    <a href="{{ path('app_categorie_index') }}" class="btn btn-secondary btn-sm">Voir</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-sm-6 col-lg-4 col-xl-2">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <i class="fas fa-calendar-check fa-2x text-warning mb-2"></i>
                                    <h5 class="card-title">Réservations</h5>
                                    <h2 class="display-6">{{ reservationCount }}</h2>
                                    <p class="card-text">Gérer les réservations</p>
                                    <a href="{{ path('app_reservation_index') }}" class="btn btn-warning btn-sm">Voir</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-chart-bar"></i> Statistiques Rapides
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <div class="border-end">
                                <h3 class="text-primary">{{ 'now'|date('m') }}</h3>
                                <p class="text-muted mb-0">Mois actuel</p>
                            </div>
                        </div>
                        <div class="col-6">
                            <h3 class="text-success">{{ 'now'|date('Y') }}</h3>
                            <p class="text-muted mb-0">Année</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-clock"></i> Activité Récente
                    </h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <div class="list-group-item">
                            <small class="text-muted">{{ 'now'|date('d/m/Y H:i') }}</small>
                            <p class="mb-0">Connexion au dashboard</p>
                        </div>
                        <div class="list-group-item">
                            <small class="text-muted">Système</small>
                            <p class="mb-0">Dashboard initialisé</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="mt-5 py-4 bg-light text-center">
        <div class="container">
            <p class="mb-0 text-muted">
                &copy; {{ 'now'|date('Y') }} BiblioConnect - Système de Gestion de Bibliothèque
            </p>
        </div>
    </footer>
</div>

<!-- Add Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
{% endblock %}