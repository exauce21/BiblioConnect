{% extends 'base.html.twig' %}

{% block title %}Hello LoginController!
{% endblock %}

{% block body %}
	<div class="modal modal-sheet position-static d-block p-4 py-md-5" tabindex="-1" role="dialog" id="modalSignin">
		<div class="modal-dialog">
			<div class="modal-content rounded-0">
				<div class="modal-header p-5 pb-4 border-bottom-0">
					<h1 class="fw-bold mb-0 fs-2">Se connecter</h1>
				</div>
				<div class="modal-body p-5 pt-0">
					<form class="" action="{{ path('app_login') }}" method="post">
						<div class="form-floating mb-3">
							<input name="_username" type="email" class="form-control rounded-3" id="floatingInput" placeholder="name@example.com">
							<label for="floatingInput">Email address</label>
						</div>
						<div class="form-floating mb-3">
							<input name="_password" type="password" class="form-control rounded-3" id="floatingPassword" placeholder="Mot de passe">
							<label for="floatingPassword">Password</label>
						</div>
						<button class="w-100 mb-2 btn btn-lg rounded-3 btn-primary" type="submit">Se connecter</button>
						<small class="text-body-secondary">By clicking Se connecter, you agree to the terms of use.</small>
					</form>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
