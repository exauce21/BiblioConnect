{% extends 'admin/base.html.twig' %}

{% block admin_title %}Modifier l'auteur{% endblock %}

{% block admin_body %}
    <div class="card shadow-sm">
        <div class="card-header">
            <h2 class="h5 mb-0">Modifier l'auteur</h2>
        </div>
        <div class="card-body">
            {{ include('auteur/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('app_auteur_index') }}" class="btn btn-secondary btn-sm">Retour à la liste</a>
            {{ include('bibliothecaire/auteur/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
