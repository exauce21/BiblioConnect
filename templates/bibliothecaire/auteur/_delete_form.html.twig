<form method="post" action="{{ path('app_auteur_delete', {'id': auteur.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cet auteur ?');" class="d-inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ auteur.id) }}">
    <button class="btn btn-danger btn-sm">Supprimer</button>
</form>
