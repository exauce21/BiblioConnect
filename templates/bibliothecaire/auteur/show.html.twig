{% extends 'admin/base.html.twig' %}

{% block admin_title %}Auteur{% endblock %}

{% block admin_body %}
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="h5 mb-0">Détails de l'auteur</h2>
                <p class="text-muted small mb-0">Voir les informations et gérer l'auteur.</p>
            </div>
            <div>
                <a href="{{ path('app_auteur_edit', {'id': auteur.id}) }}" class="btn btn-sm btn-primary me-2">Modifier</a>
                {{ include('auteur/_delete_form.html.twig') }}
            </div>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">{{ auteur.id }}</dd>

                <dt class="col-sm-3">Nom</dt>
                <dd class="col-sm-9">{{ auteur.nom }}</dd>

                <dt class="col-sm-3">Biographie</dt>
                <dd class="col-sm-9">{{ auteur.biographie|default('Aucune biographie fournie.') }}</dd>
            </dl>
        </div>
        <div class="card-footer text-end">
            <a href="{{ path('app_auteur_index') }}" class="btn btn-secondary btn-sm">Retour à la liste</a>
        </div>
    </div>
{% endblock %}
