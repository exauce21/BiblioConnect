{% extends 'admin/base.html.twig' %}

{% block admin_title %}Langues{% endblock %}

{% block admin_body %}
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="h5 mb-0">Liste des langues</h2>
                <p class="text-muted small mb-0">Gérez les langues de la bibliothèque.</p>
            </div>
            <a href="{{ path('app_langue_new') }}" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i> Ajouter une langue
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Titre</th>
                            <th scope="col">Code</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for langue in langues %}
                        <tr>
                            <td>{{ langue.id }}</td>
                            <td>{{ langue.titre }}</td>
                            <td><code>{{ langue.code }}</code></td>
                            <td class="text-end">
                                <a href="{{ path('app_langue_show', {'id': langue.id}) }}" class="btn btn-sm btn-outline-secondary me-1">Voir</a>
                                <a href="{{ path('app_langue_edit', {'id': langue.id}) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-4">Aucune langue trouvée.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
