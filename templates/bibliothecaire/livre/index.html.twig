{% extends 'admin/base.html.twig' %}

{% block admin_title %}Livres{% endblock %}

{% block admin_body %}
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h2 class="h5 mb-0">Liste des livres</h2>
                <p class="text-muted small mb-0">Gérez les livres de la bibliothèque.</p>
            </div>
            <a href="{{ path('app_livre_new') }}" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i> Ajouter un livre
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Titre</th>
                            <th scope="col">Description</th>
                            <th scope="col">Année</th>
                            <th scope="col">Stock total</th>
                            <th scope="col">Stock disponible</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for livre in livres %}
                        <tr>
                            <td>{{ livre.id }}</td>
                            <td>{{ livre.titre }}</td>
                            <td>{{ livre.description|length > 100 ? livre.description[:100] ~ '...' : livre.description }}</td>
                            <td>{{ livre.annee }}</td>
                            <td>{{ livre.stockTotal }}</td>
                            <td>{{ livre.stockDisponible }}</td>
                            <td class="text-end">
                                <a href="{{ path('app_livre_show', {'id': livre.id}) }}" class="btn btn-sm btn-outline-secondary me-1">Voir</a>
                                <a href="{{ path('app_livre_edit', {'id': livre.id}) }}" class="btn btn-sm btn-outline-primary">Modifier</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center py-4">Aucun livre trouvé.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
